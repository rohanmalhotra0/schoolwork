# Copy this file to `.env.local` (gitignored) and fill in your key.
# On Vercel, set these in Project Settings → Environment Variables (never commit).

# OpenAI API key — used by /api/chat to call the model.
OPENAI_KEY=sk-your-key-here

# Default model. Keep as-is unless you want a different one.
OPENAI_MODEL=gpt-4o-mini
