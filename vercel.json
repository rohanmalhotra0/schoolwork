{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/chat.js": {
      "maxDuration": 60,
      "includeFiles": "{Politics,Oracle,German,StudyTool}/content.js"
    },
    "api/content.js": {
      "maxDuration": 10,
      "includeFiles": "{Politics,Oracle,German,StudyTool}/content.js"
    },
    "api/transcribe.js": {
      "maxDuration": 30
    },
    "api/tts.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" }
      ]
    }
  ]
}
